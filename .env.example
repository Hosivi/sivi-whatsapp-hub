# .env.example — environment variables for sivi-whatsapp-hub
# Copy to .env (backend) or apps/web/.env.local and fill in real values.
# NEVER commit real secrets to version control.

# -- Backend (apps/backend) ---------------------------------------------------

# PostgreSQL connection for the app_rls role (RLS enforced).
DATABASE_URL=postgresql://app_rls:<password>@localhost:5432/hub

# PostgreSQL connection for the admin/migration role (superuser).
DATABASE_ADMIN_URL=postgresql://postgres:<password>@localhost:5432/hub

# PostgreSQL connection for the app_webhook role (low-privilege cross-tenant lookup).
DATABASE_WEBHOOK_URL=postgresql://app_webhook:<password>@localhost:5432/hub

# Authentication mode: dev-header (X-Tenant-Id) or jwt.
AUTH_MODE=dev-header

# HTTP port for the backend server.
PORT=3001

# Log level: trace | debug | info | warn | error | silent.
LOG_LEVEL=info

# Meta WhatsApp Cloud API global credentials (one Meta App per Hub instance).
WHATSAPP_VERIFY_TOKEN=<your-meta-webhook-verify-token>
WHATSAPP_APP_SECRET=<your-meta-app-secret>

# Dev console: set to true to mount /dev/* routes + CORS. Default false = prod-safe.
ENABLE_DEV_ENDPOINTS=false

# Optional: production password for the app_webhook role.
# APP_WEBHOOK_PASSWORD=<password>

# Optional: production password for the app_rls role (used by makeIdempotent during migrate).
# APP_RLS_PASSWORD=<password>

# -- apps/web -----------------------------------------------------------------

# Backend base URL for the dev console (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dev seed tenant UUID (matches DEV_TENANT_ID in seed-dev.ts).
NEXT_PUBLIC_DEFAULT_TENANT_ID=<dev-seed-uuid-placeholder>
